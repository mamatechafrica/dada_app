<!-- Start Your Journey Modal -->
<div class="modal fade" id="onboardingModal" tabindex="-1" aria-labelledby="onboardingModalLabel" aria-hidden="true" 
     data-controller="onboarding" data-onboarding-target="modal">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body px-5 py-4">
        <!-- Progress Indicator -->
        <div class="mb-4">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">Step <span data-onboarding-target="stepCounter">1 of 4</span></small>
            <small class="text-muted fw-light">✨ You're doing something kind for yourself today</small>
          </div>
          <div class="progress" style="height: 4px;">
            <div class="progress-bar bg-primary" role="progressbar" style="width: 25%;" 
                 aria-valuenow="25" aria-valuemin="0" aria-valuemax="100" data-onboarding-target="progressBar"></div>
          </div>
        </div>

        <!-- Step 1: Welcome & Stage -->
        <div data-onboarding-target="step" class="text-center">
          <h2 class="display-6 fw-bold mb-3">✨ Start Your Journey</h2>
          <p class="lead text-secondary mb-4">Every journey through menopause is different. Tell us where you are — we'll meet you there.</p>
          <div class="d-grid">
            <button class="btn btn-primary btn-lg px-5" data-action="click->onboarding#next">Start Now</button>
          </div>
        </div>

        <!-- Step 2: Menopause Stage -->
        <div data-onboarding-target="step" class="d-none">
          <h2 class="display-6 fw-bold mb-3">🧭 Where are you in your menopause journey?</h2>
          <p class="lead text-secondary mb-4">This helps us show you the most relevant content and community.</p>
          
          <div class="mb-4">
            <div class="form-check mb-3 p-3 rounded border bg-light">
              <input class="form-check-input" type="radio" name="menopause_stage" id="perimenopause" value="perimenopause">
              <label class="form-check-label fs-5" for="perimenopause">
                I think I'm in <strong>perimenopause</strong>
              </label>
            </div>
            <div class="form-check mb-3 p-3 rounded border bg-light">
              <input class="form-check-input" type="radio" name="menopause_stage" id="menopause" value="menopause">
              <label class="form-check-label fs-5" for="menopause">
                I'm currently in <strong>menopause</strong>
              </label>
            </div>
            <div class="form-check mb-3 p-3 rounded border bg-light">
              <input class="form-check-input" type="radio" name="menopause_stage" id="post-menopause" value="post-menopause">
              <label class="form-check-label fs-5" for="post-menopause">
                I'm <strong>post-menopause</strong>
              </label>
            </div>
            <div class="form-check mb-3 p-3 rounded border bg-light">
              <input class="form-check-input" type="radio" name="menopause_stage" id="not-sure" value="exploring">
              <label class="form-check-label fs-5" for="not-sure">
                Honestly, <strong>I'm not sure</strong>
              </label>
            </div>
          </div>
          
          <p class="text-muted small mb-4">💝 There's no "right" answer. Just your truth.</p>
        </div>

        <!-- Step 3: Symptoms -->
        <div data-onboarding-target="step" class="d-none">
          <h2 class="display-6 fw-bold mb-3">🩺 What symptoms are showing up for you?</h2>
          <p class="lead text-secondary mb-4">Choose all that apply. You can skip this if you're not ready.</p>
          
          <div class="row mb-4">
            <div class="col-md-6">
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="hot_flashes" id="hot_flashes">
                <label class="form-check-label" for="hot_flashes">Hot flashes</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="trouble_sleeping" id="trouble_sleeping">
                <label class="form-check-label" for="trouble_sleeping">Trouble sleeping</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="mood_changes" id="mood_changes">
                <label class="form-check-label" for="mood_changes">Mood changes</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="anxiety" id="anxiety">
                <label class="form-check-label" for="anxiety">Anxiety</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="brain_fog" id="brain_fog">
                <label class="form-check-label" for="brain_fog">Brain fog</label>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="irregular_periods" id="irregular_periods">
                <label class="form-check-label" for="irregular_periods">Irregular periods</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="vaginal_dryness" id="vaginal_dryness">
                <label class="form-check-label" for="vaginal_dryness">Vaginal dryness</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="low_libido" id="low_libido">
                <label class="form-check-label" for="low_libido">Low libido</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="weight_changes" id="weight_changes">
                <label class="form-check-label" for="weight_changes">Weight changes</label>
              </div>
              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="symptoms[]" value="not_sure_symptoms" id="not_sure_symptoms">
                <label class="form-check-label" for="not_sure_symptoms">I'm not sure</label>
              </div>
            </div>
          </div>
          
          <p class="text-muted small mb-4">🌱 It's okay to not have it all figured out.</p>
          
          <div class="text-center mb-3">
            <button type="button" class="btn btn-link text-decoration-none" data-action="click->onboarding#skip">
              Skip this step
            </button>
          </div>
        </div>

        <!-- Step 4: Location -->
        <div data-onboarding-target="step" class="d-none">
          <h2 class="display-6 fw-bold mb-3">🌍 Where are you located?</h2>
          <p class="lead text-secondary mb-4">We'll use this to recommend local resources and connect you with nearby Circles.</p>
          
          <div class="mb-4">
            <div class="input-group input-group-lg">
              <span class="input-group-text">📍</span>
              <input type="text" class="form-control" name="location" placeholder="Enter city or ZIP code" 
                     data-onboarding-target="locationInput">
            </div>
          </div>
          
          <p class="text-muted small mb-4">🤗 We're here to support you, wherever you are.</p>
        </div>

        <!-- Step 5: Completion -->
        <div data-onboarding-target="step" class="d-none text-center">
          <h2 class="display-6 fw-bold mb-3">🧡 Welcome, friend — you're not alone in this.</h2>
          <p class="lead text-secondary mb-4">
            <span data-onboarding-target="personalizedMessage">
              You're navigating your unique journey, and we see you. Here's content and community made for women just like you.
            </span>
          </p>
          
          <div class="row text-start mb-4">
            <div class="col-md-4 mb-3">
              <div class="d-flex align-items-center">
                <span class="fs-4 me-3">📚</span>
                <div>
                  <h6 class="mb-1">Your Content Bundle</h6>
                  <small class="text-muted">Articles curated for your journey</small>
                </div>
              </div>
            </div>
            <div class="col-md-4 mb-3">
              <div class="d-flex align-items-center">
                <span class="fs-4 me-3">🧵</span>
                <div>
                  <h6 class="mb-1">Join a Circle</h6>
                  <small class="text-muted">Women nearby who get it</small>
                </div>
              </div>
            </div>
            <div class="col-md-4 mb-3">
              <div class="d-flex align-items-center">
                <span class="fs-4 me-3">💬</span>
                <div>
                  <h6 class="mb-1">Real Talk</h6>
                  <small class="text-muted">Forum threads from others like you</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="modal-footer border-0 pt-0 px-5 pb-4">
        <div class="d-flex justify-content-between w-100">
          <button type="button" class="btn btn-outline-secondary" data-action="click->onboarding#previous" 
                  data-onboarding-target="prevBtn" disabled>
            Previous
          </button>
          <button type="button" class="btn btn-primary px-4" data-action="click->onboarding#handleNext" 
                  data-onboarding-target="nextBtn">
            Next
          </button>
        </div>
      </div>
    </div>
  </div>
</div>