<!-- Onboarding Modal -->
<div class="modal fade" id="onboardingModal" tabindex="-1" aria-labelledby="onboardingModalLabel" aria-hidden="true" 
     data-controller="onboarding" data-onboarding-target="modal">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <div class="w-100">
          <!-- Progress Bar -->
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="modal-title" id="onboardingModalLabel">Welcome to Dada</h5>
            <span class="text-muted small" data-onboarding-target="stepCounter">1 of 6</span>
          </div>
          <div class="progress" style="height: 6px;">
            <div class="progress-bar bg-primary" role="progressbar" 
                 data-onboarding-target="progressBar" 
                 style="width: 16.67%" 
                 aria-valuenow="16.67" 
                 aria-valuemin="0" 
                 aria-valuemax="100"></div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <div class="modal-body px-4 py-4">
        <!-- Step 1: Welcome -->
        <div data-onboarding-target="step" class="">
          <div class="text-center mb-4">
            <span class="fs-1 mb-3 d-block">🌺</span>
            <h3 class="fw-bold mb-3">Welcome to Your <span class="text-primary-accent">Menopause Journey</span></h3>
            <p class="lead text-secondary">
              Dada is here to support you through midlife with culturally-aware guidance, 
              personalized insights, and a community that understands your experience.
            </p>
          </div>
          <div class="row g-3">
            <div class="col-md-4 text-center">
              <div class="p-3 bg-light rounded">
                <span class="fs-4 d-block mb-2">🤖</span>
                <h6 class="fw-semibold">AI-Powered Support</h6>
                <small class="text-muted">Get personalized guidance</small>
              </div>
            </div>
            <div class="col-md-4 text-center">
              <div class="p-3 bg-light rounded">
                <span class="fs-4 d-block mb-2">🌍</span>
                <h6 class="fw-semibold">Cultural Awareness</h6>
                <small class="text-muted">Rooted in African wisdom</small>
              </div>
            </div>
            <div class="col-md-4 text-center">
              <div class="p-3 bg-light rounded">
                <span class="fs-4 d-block mb-2">👥</span>
                <h6 class="fw-semibold">Sister Community</h6>
                <small class="text-muted">Connect with other women</small>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Personal Information -->
        <div data-onboarding-target="step" class="d-none">
          <div class="text-center mb-4">
            <span class="fs-1 mb-3 d-block">👤</span>
            <h3 class="fw-bold mb-3">Tell Us About <span class="text-primary-accent">Yourself</span></h3>
            <p class="text-secondary">
              Help us personalize your experience by sharing some basic information.
            </p>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label for="age-range" class="form-label fw-semibold">Age Range</label>
              <select class="form-select" id="age-range">
                <option value="">Choose your age range</option>
                <option value="35-40">35-40 years</option>
                <option value="41-45">41-45 years</option>
                <option value="46-50">46-50 years</option>
                <option value="51-55">51-55 years</option>
                <option value="56-60">56-60 years</option>
                <option value="60+">60+ years</option>
              </select>
            </div>
            <div class="col-md-6">
              <label for="location" class="form-label fw-semibold">Location</label>
              <select class="form-select" id="location">
                <option value="">Select your location</option>
                <option value="nigeria">Nigeria</option>
                <option value="kenya">Kenya</option>
                <option value="ghana">Ghana</option>
                <option value="south-africa">South Africa</option>
                <option value="uganda">Uganda</option>
                <option value="diaspora-us">Diaspora - United States</option>
                <option value="diaspora-uk">Diaspora - United Kingdom</option>
                <option value="diaspora-canada">Diaspora - Canada</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="col-12">
              <label for="menopause-stage" class="form-label fw-semibold">Where are you in your menopause journey?</label>
              <div class="row g-2">
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="menopause-stage" id="premenopause" value="premenopause">
                    <label class="form-check-label" for="premenopause">
                      <strong>Pre-menopause</strong><br>
                      <small class="text-muted">Regular periods, some changes</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="menopause-stage" id="perimenopause" value="perimenopause">
                    <label class="form-check-label" for="perimenopause">
                      <strong>Perimenopause</strong><br>
                      <small class="text-muted">Irregular periods, symptoms</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="menopause-stage" id="postmenopause" value="postmenopause">
                    <label class="form-check-label" for="postmenopause">
                      <strong>Post-menopause</strong><br>
                      <small class="text-muted">No periods for 12+ months</small>
                    </label>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: Symptoms & Concerns -->
        <div data-onboarding-target="step" class="d-none">
          <div class="text-center mb-4">
            <span class="fs-1 mb-3 d-block">🩺</span>
            <h3 class="fw-bold mb-3">Your <span class="text-primary-accent">Symptoms & Concerns</span></h3>
            <p class="text-secondary">
              Select the symptoms you're experiencing. This helps us provide relevant support.
            </p>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <h6 class="fw-semibold mb-3">Physical Symptoms</h6>
              <div class="d-flex flex-wrap gap-2">
                <input type="checkbox" class="btn-check" id="hot-flashes" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="hot-flashes">Hot Flashes</label>
                
                <input type="checkbox" class="btn-check" id="night-sweats" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="night-sweats">Night Sweats</label>
                
                <input type="checkbox" class="btn-check" id="irregular-periods" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="irregular-periods">Irregular Periods</label>
                
                <input type="checkbox" class="btn-check" id="sleep-issues" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="sleep-issues">Sleep Issues</label>
                
                <input type="checkbox" class="btn-check" id="weight-changes" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="weight-changes">Weight Changes</label>
                
                <input type="checkbox" class="btn-check" id="joint-pain" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="joint-pain">Joint Pain</label>
              </div>
            </div>
            <div class="col-md-6">
              <h6 class="fw-semibold mb-3">Emotional & Mental</h6>
              <div class="d-flex flex-wrap gap-2">
                <input type="checkbox" class="btn-check" id="mood-swings" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="mood-swings">Mood Swings</label>
                
                <input type="checkbox" class="btn-check" id="anxiety" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="anxiety">Anxiety</label>
                
                <input type="checkbox" class="btn-check" id="depression" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="depression">Low Mood</label>
                
                <input type="checkbox" class="btn-check" id="brain-fog" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="brain-fog">Brain Fog</label>
                
                <input type="checkbox" class="btn-check" id="irritability" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="irritability">Irritability</label>
                
                <input type="checkbox" class="btn-check" id="low-energy" autocomplete="off">
                <label class="btn btn-outline-secondary btn-sm" for="low-energy">Low Energy</label>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4: Cultural Background & Preferences -->
        <div data-onboarding-target="step" class="d-none">
          <div class="text-center mb-4">
            <span class="fs-1 mb-3 d-block">🌍</span>
            <h3 class="fw-bold mb-3">Your <span class="text-primary-accent">Cultural Context</span></h3>
            <p class="text-secondary">
              Help us understand your cultural background to provide more relevant guidance.
            </p>
          </div>
          <div class="row g-3">
            <div class="col-12">
              <label for="ethnicity" class="form-label fw-semibold">Cultural/Ethnic Background</label>
              <select class="form-select" id="ethnicity">
                <option value="">Select your background</option>
                <option value="yoruba">Yoruba</option>
                <option value="igbo">Igbo</option>
                <option value="hausa">Hausa</option>
                <option value="kikuyu">Kikuyu</option>
                <option value="luo">Luo</option>
                <option value="akan">Akan</option>
                <option value="zulu">Zulu</option>
                <option value="xhosa">Xhosa</option>
                <option value="east-african">East African</option>
                <option value="west-african">West African</option>
                <option value="southern-african">Southern African</option>
                <option value="diaspora-mixed">Diaspora - Mixed Heritage</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Traditional remedies interest</label>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="traditional-interest" id="very-interested" value="very-interested">
                <label class="form-check-label" for="very-interested">Very interested</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="traditional-interest" id="somewhat-interested" value="somewhat-interested">
                <label class="form-check-label" for="somewhat-interested">Somewhat interested</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="traditional-interest" id="not-interested" value="not-interested">
                <label class="form-check-label" for="not-interested">Not interested</label>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Community support preference</label>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="community-preference" id="active-community" value="active-community">
                <label class="form-check-label" for="active-community">Active community participation</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="community-preference" id="read-only" value="read-only">
                <label class="form-check-label" for="read-only">Read stories, less participation</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="community-preference" id="private" value="private">
                <label class="form-check-label" for="private">Prefer private guidance</label>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 5: Goals & Expectations -->
        <div data-onboarding-target="step" class="d-none">
          <div class="text-center mb-4">
            <span class="fs-1 mb-3 d-block">🎯</span>
            <h3 class="fw-bold mb-3">Your <span class="text-primary-accent">Goals & Expectations</span></h3>
            <p class="text-secondary">
              What do you hope to achieve with Dada? Select your main priorities.
            </p>
          </div>
          <div class="row g-3">
            <div class="col-12">
              <h6 class="fw-semibold mb-3">What would you like help with? (Select all that apply)</h6>
              <div class="row g-2">
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="symptom-management" value="symptom-management">
                    <label class="form-check-label" for="symptom-management">
                      <strong>Symptom Management</strong><br>
                      <small class="text-muted">Natural remedies, coping strategies</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="emotional-support" value="emotional-support">
                    <label class="form-check-label" for="emotional-support">
                      <strong>Emotional Support</strong><br>
                      <small class="text-muted">Dealing with mood changes, anxiety</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="lifestyle-guidance" value="lifestyle-guidance">
                    <label class="form-check-label" for="lifestyle-guidance">
                      <strong>Lifestyle Guidance</strong><br>
                      <small class="text-muted">Diet, exercise, wellness practices</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="family-relationships" value="family-relationships">
                    <label class="form-check-label" for="family-relationships">
                      <strong>Family Relationships</strong><br>
                      <small class="text-muted">Talking to family, partner support</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="career-balance" value="career-balance">
                    <label class="form-check-label" for="career-balance">
                      <strong>Career & Life Balance</strong><br>
                      <small class="text-muted">Managing work, energy, priorities</small>
                    </label>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="preparing-future" value="preparing-future">
                    <label class="form-check-label" for="preparing-future">
                      <strong>Preparing for the Future</strong><br>
                      <small class="text-muted">Long-term health, aging gracefully</small>
                    </label>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 6: Complete -->
        <div data-onboarding-target="step" class="d-none">
          <div class="text-center">
            <span class="fs-1 mb-3 d-block">🎉</span>
            <h3 class="fw-bold mb-3">You're All Set, <span class="text-primary-accent">Sister!</span></h3>
            <p class="lead text-secondary mb-4">
              Welcome to the Dada community! Your personalized menopause journey starts now.
            </p>
            <div class="row g-3 mb-4">
              <div class="col-md-4">
                <div class="p-3 bg-light rounded">
                  <span class="fs-4 d-block mb-2 text-primary-accent">✨</span>
                  <h6 class="fw-semibold">Personalized AI Chat</h6>
                  <small class="text-muted">Ready to answer your questions</small>
                </div>
              </div>
              <div class="col-md-4">
                <div class="p-3 bg-light rounded">
                  <span class="fs-4 d-block mb-2 text-primary-accent">📚</span>
                  <h6 class="fw-semibold">Curated Resources</h6>
                  <small class="text-muted">Tailored to your needs</small>
                </div>
              </div>
              <div class="col-md-4">
                <div class="p-3 bg-light rounded">
                  <span class="fs-4 d-block mb-2 text-primary-accent">👭</span>
                  <h6 class="fw-semibold">Sister Stories</h6>
                  <small class="text-muted">Connect with your community</small>
                </div>
              </div>
            </div>
            <div class="alert alert-info" role="alert">
              <strong>Pro tip:</strong> Check out the AI chat below to ask your first question, or explore the sister stories to see how other women are thriving!
            </div>
          </div>
        </div>
      </div>
      
      <div class="modal-footer border-0 pt-0">
        <div class="d-flex justify-content-between w-100">
          <button type="button" class="btn btn-outline-secondary" 
                  data-action="click->onboarding#previous"
                  data-onboarding-target="prevBtn">Previous</button>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" 
                    data-action="click->onboarding#skip">Skip</button>
            <button type="button" class="btn btn-primary" 
                    data-action="click->onboarding#handleNext"
                    data-onboarding-target="nextBtn">Next</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>