<section class="py-5 bg-white">
  <div class="container">
    <div class="text-center mb-4">
      <span class="badge bg-warning text-dark mb-2" style="font-size: 1rem;">
        <i class="bi bi-stars me-2"></i>
        AI-Powered Support
      </span>
      <h2 class="fw-bold display-4 mb-2" style="letter-spacing: -1px;">
        Chat with Your <span style="color: #fd7e14;">AI Companion</span>
      </h2>
      <p class="lead mb-0" style="max-width: 600px; margin: 0 auto;">
        Get personalized menopause guidance powered by AI and trained on culturally-relevant content from our community.
      </p>
    </div>
    <div class="mx-auto" style="max-width: 700px;">
      <div class="card shadow mb-3">
        <div class="card-header bg-gradient" style="background: linear-gradient(90deg, #f76b1c 0%, #ffb347 100%); color: #fff;">
          <i class="bi bi-robot me-2"></i>
          MenoBuddy AI Assistant
        </div>
        <div class="card-body" style="min-height: 180px;">
          <div class="mb-3">
            <div class="bg-light rounded p-3 text-start">
              <i class="bi bi-robot me-2"></i>
              Hello! I'm your MenoBuddy AI assistant. I'm here to help you navigate your menopause journey with culturally-aware guidance. How can I support you today?
            </div>
          </div>
          <div class="mb-2">
            <small class="text-muted">Quick questions:</small>
            <div>
              <button class="btn btn-sm btn-outline-warning rounded-pill m-1">What are common menopause symptoms?</button>
              <button class="btn btn-sm btn-outline-warning rounded-pill m-1">Natural remedies for hot flashes</button>
              <button class="btn btn-sm btn-outline-warning rounded-pill m-1">Menopause and African traditional medicine</button>
              <button class="btn btn-sm btn-outline-warning rounded-pill m-1">How to talk to family about menopause</button>
            </div>
          </div>
          <form class="d-flex mt-3">
            <input type="text" class="form-control me-2" placeholder="Ask me about menopause, symptoms, or cultural practices..." />
            <button class="btn btn-warning text-white" type="submit">
              <i class="bi bi-send"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
