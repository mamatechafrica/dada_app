<div class="min-h-screen flex items-center justify-center bg-dada-background dark:bg-dada-darkBg p-6">
  <div class="bg-white dark:bg-zinc-800 shadow-lg rounded-lg p-8 w-full max-w-md">
    <h2 class="text-2xl sm:text-3xl font-bold text-dada-text dark:text-white mb-6 text-center">
      Change your password
    </h2>

    <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put, local: true do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <% if @minimum_password_length %>
        <p class="text-xs text-dada-subtle dark:text-zinc-400 mb-1">
          Minimum <%= @minimum_password_length %> characters
        </p>
      <% end %>
      <%= render "devise/shared/password_field", f: f, field: :password, label_text: "New password", placeholder_text: "Enter new password", autocomplete: "new-password" %>

      <%= render "devise/shared/password_field", f: f, field: :password_confirmation, label_text: "Confirm new password", placeholder_text: "Confirm new password", autocomplete: "new-password" %>

      <%= f.submit "Change my password",
                   class: "w-full bg-dada-primary hover:bg-dada-accent text-white font-semibold py-2 rounded transition" %>
    <% end %>

    <div class="text-center text-sm mt-6 text-dada-subtle dark:text-zinc-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
