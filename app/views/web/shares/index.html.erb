<div class="px-40 flex flex-1 justify-center py-5 max-lg:px-4">
  <div class="layout-content-container flex flex-col max-w-[960px] flex-1">
    <div class="flex flex-wrap justify-between gap-3 p-4">
      <div class="flex min-w-72 flex-col gap-3">
        <p class="text-[#181311] dark:text-white tracking-light text-[32px] font-bold leading-tight">Community Stories</p>
        <p class="text-[#886b63] dark:text-zinc-400 text-sm font-normal leading-normal">Real stories from women in the community.</p>
      </div>
    </div>
    <div class="pb-3">
      <div class="flex border-b border-[#e5dedc] dark:border-zinc-700 px-4 gap-8 overflow-x-auto">
        <a class="flex flex-col items-center justify-center border-b-[3px] <%= @content_type == 'text' ? 'border-b-dada-primary text-dada-primary' : 'border-b-transparent text-[#886b63]' %> gap-1 pb-[7px] pt-2.5 whitespace-nowrap" href="/content?type=text">
          <p class="text-sm font-bold leading-normal tracking-[0.015em]">Stories</p>
        </a>
        <a class="flex flex-col items-center justify-center border-b-[3px] <%= @content_type == 'image' ? 'border-b-dada-primary text-dada-primary' : 'border-b-transparent text-[#886b63]' %> gap-1 pb-[7px] pt-2.5 whitespace-nowrap" href="/content?type=image">
          <p class="text-sm font-bold leading-normal tracking-[0.015em]">Photos</p>
        </a>
        <a class="flex flex-col items-center justify-center border-b-[3px] <%= @content_type == 'video' ? 'border-b-dada-primary text-dada-primary' : 'border-b-transparent text-[#886b63]' %> gap-1 pb-[7px] pt-2.5 whitespace-nowrap" href="/content?type=video">
          <p class="text-sm font-bold leading-normal tracking-[0.015em]">Videos</p>
        </a>
      </div>
    </div>

    <% if @shares.any? %>
      <% @shares.each do |share| %>
        <div class="flex gap-4 bg-white dark:bg-zinc-800 px-4 py-3 justify-between items-center">
          <div class="flex items-start gap-4 flex-1 min-w-0">
            <div class="text-[#181311] dark:text-white flex items-center justify-center rounded-lg bg-[#f4f1f0] dark:bg-zinc-700 shrink-0 size-12">
              <% case share.share_type %>
              <% when 'text' %>
                <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M184,112a8,8,0,0,1-8,8H112a8,8,0,0,1,0-16h64A8,8,0,0,1,184,112Zm-8,24H112a8,8,0,0,0,0,16h64a8,8,0,0,0,0-16Zm48-88V208a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V48A16,16,0,0,1,48,32H208A16,16,0,0,1,224,48Z"></path>
                </svg>
              <% when 'image' %>
                <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Z"></path>
                </svg>
              <% when 'video' %>
                <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" fill="currentColor" viewBox="0 0 256 256">
                  <path d="M164.44,105.34l-48-32A8,8,0,0,0,104,80v64a8,8,0,0,0,12.44,6.66l48-32a8,8,0,0,0,0-13.32Z"></path>
                </svg>
              <% end %>
            </div>
            <div class="flex flex-1 flex-col justify-center min-w-0">
              <p class="text-[#181311] dark:text-white text-base font-medium leading-normal truncate"><%= share.title || "Untitled" %></p>
              <% if share.content.present? %>
                <p class="text-[#886b63] dark:text-zinc-400 text-sm font-normal leading-normal line-clamp-2"><%= truncate(strip_tags(share.content), length: 100) %></p>
              <% end %>
            </div>
          </div>
          <div class="shrink-0">
            <a href="/content/<%= share.id %>" class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-4 bg-[#f4f1f0] dark:bg-zinc-700 text-[#181311] dark:text-white text-sm font-medium leading-normal w-fit hover:bg-dada-secondary transition-colors">
              <span class="truncate">
                <%= share.share_type == 'text' ? 'Read' : share.share_type == 'image' ? 'View' : 'Watch' %>
              </span>
            </a>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex gap-4 bg-white dark:bg-zinc-800 px-4 py-3 justify-between">
        <div class="flex items-start gap-4 flex-1">
          <div class="flex flex-col justify-center">
            <p class="text-[#181311] dark:text-white text-base font-medium leading-normal">No stories yet</p>
            <p class="text-[#886b63] dark:text-zinc-400 text-sm font-normal leading-normal">Be the first to share your story!</p>
          </div>
        </div>
        <div class="shrink-0">
          <a href="<%= user_signed_in? ? '/web/shares/new' : '/users/sign_in' %>" class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-8 px-4 bg-dada-primary text-white text-sm font-medium leading-normal w-fit hover:bg-dada-accent transition-colors">
            <span class="truncate">Share Story</span>
          </a>
        </div>
      </div>
    <% end %>
  </div>
</div>
