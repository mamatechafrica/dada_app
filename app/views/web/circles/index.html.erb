<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-dada-text dark:text-white mb-4">Join the Conversation</h1>
    <p class="text-lg text-dada-subtle dark:text-zinc-400">Connect with others who understand what you're going through</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @circles.each do |circle| %>
        <a href="<%= circle_path(circle) %>" class="block bg-white dark:bg-zinc-800 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all border-t-4" style="border-color: <%= circle.color || '#E84D4D' %>">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background-color: <%= circle.color || '#E84D4D' %>20">
            <svg class="w-6 h-6" style="color: <%= circle.color || '#E84D4D' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <span class="text-sm text-dada-subtle"><%= circle.topics.count %> topics</span>
        </div>
        
        <h3 class="text-xl font-bold text-dada-text dark:text-white mb-2"><%= circle.name %></h3>
        <p class="text-sm text-dada-subtle dark:text-zinc-400"><%= circle.description %></p>
        
        <div class="mt-4 flex items-center text-dada-primary font-medium">
          <span>Join Discussion</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    <% end %>
  </div>

  <div class="mt-12 bg-dada-secondary/20 rounded-xl p-8 text-center">
    <h2 class="text-2xl font-bold text-dada-text dark:text-white mb-4">Start a Circle</h2>
    <p class="text-dada-subtle dark:text-zinc-400 mb-6">Don't see what you're looking for? Suggest a new topic and we'll create it.</p>
    
    <% if user_signed_in? %>
      <button id="suggestion-toggle" class="inline-block bg-dada-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-dada-accent transition">
        Suggest a Topic
      </button>
      
      <div id="suggestion-form" class="hidden mt-6 text-left max-w-md mx-auto">
        <%= form_with url: suggestions_path, local: true do |f| %>
          <div class="mb-3">
            <%= f.text_field :title, class: "w-full px-4 py-2 border border-gray-300 dark:border-zinc-600 rounded-lg bg-white dark:bg-zinc-700 text-dada-text dark:text-white", placeholder: "What topic would you like to discuss?", required: true %>
          </div>
          <div class="mb-3">
            <%= f.text_area :description, rows: 2, class: "w-full px-4 py-2 border border-gray-300 dark:border-zinc-600 rounded-lg bg-white dark:bg-zinc-700 text-dada-text dark:text-white", placeholder: "Brief description (optional)" %>
          </div>
          <div class="flex gap-2 justify-center">
            <%= f.submit "Submit", class: "bg-dada-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-dada-accent cursor-pointer" %>
            <button type="button" id="suggestion-cancel" class="px-4 py-2 text-dada-subtle hover:text-dada-text">Cancel</button>
          </div>
        <% end %>
      </div>
      
      <script>
        document.getElementById('suggestion-toggle').addEventListener('click', function() {
          document.getElementById('suggestion-form').classList.remove('hidden');
          this.classList.add('hidden');
        });
        document.getElementById('suggestion-cancel').addEventListener('click', function() {
          document.getElementById('suggestion-form').classList.add('hidden');
          document.getElementById('suggestion-toggle').classList.remove('hidden');
        });
      </script>
    <% else %>
      <a href="/users/sign_in" class="inline-block bg-dada-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-dada-accent transition">
        Sign In to Participate
      </a>
    <% end %>
  </div>
</div>
