<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="<%= circle_path(@circle) %>" class="text-dada-primary hover:underline inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to <%= @circle.name %>
    </a>
  </div>

  <div class="bg-white dark:bg-zinc-800 rounded-xl shadow-sm border border-gray-100 dark:border-zinc-700 p-6">
    <h1 class="text-2xl font-bold text-dada-text dark:text-white mb-2">Start a New Discussion</h1>
    <p class="text-dada-subtle dark:text-zinc-400 mb-6">in <%= @circle.name %></p>

    <%= form_with model: @topic, url: create_topic_circle_path(@circle), local: true do |f| %>
      <div class="mb-4">
        <%= f.label :title, "Title", class: "block text-sm font-medium text-dada-text dark:text-white mb-2" %>
        <%= f.text_field :title, class: "w-full px-4 py-2 border border-gray-200 dark:border-zinc-600 rounded-lg bg-white dark:bg-zinc-700 text-dada-text dark:text-white focus:ring-2 focus:ring-dada-primary focus:border-transparent", placeholder: "What's on your mind?", required: true %>
      </div>

      <div class="mb-4">
        <%= f.label :content, "Your Message", class: "block text-sm font-medium text-dada-text dark:text-white mb-2" %>
        <%= f.text_area :content, rows: 8, class: "w-full px-4 py-2 border border-gray-200 dark:border-zinc-600 rounded-lg bg-white dark:bg-zinc-700 text-dada-text dark:text-white focus:ring-2 focus:ring-dada-primary focus:border-transparent", placeholder: "Share your thoughts, questions, or experiences...", required: true %>
      </div>

      <div class="mb-6">
        <label class="flex items-center gap-2 text-sm text-dada-subtle cursor-pointer">
          <%= f.check_box :anonymous, class: "rounded border-gray-300 text-dada-primary focus:ring-dada-primary" %>
          Post anonymously (your name won't be shown)
        </label>
      </div>

      <div class="flex gap-4">
        <%= f.submit "Create Discussion", class: "bg-dada-primary text-white px-6 py-2 rounded-lg font-medium hover:bg-dada-accent transition cursor-pointer" %>
        <a href="/circles/<%= @circle.id %>" class="px-6 py-2 rounded-lg font-medium text-dada-subtle hover:text-dada-text transition">
          Cancel
        </a>
      </div>
    <% end %>
  </div>
</div>
