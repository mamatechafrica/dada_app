<div class="text-center mb-4">
  <div class="onboarding-icon mb-3">
    <i class="fas fa-seedling fa-3x text-dada-primary"></i>
  </div>
  <p class="lead">Every woman's journey is unique. Let us know where you are.</p>
</div>

<div class="progress mb-4" style="height: 6px;">
  <div class="progress-bar bg-dada-primary" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
</div>

<%= form_with model: OpenStruct.new, url: onboarding_update_step_path(step: 'stage'), remote: true, id: 'stage-form' do |form| %>
  <div class="stage-options">
    <% [
      ['pre-menopause', 'Pre-menopause', 'Regular periods, early 40s or younger'],
      ['perimenopause', 'Perimenopause', 'Irregular periods, symptoms beginning'],
      ['menopause', 'Menopause', '12+ months without periods'],
      ['post-menopause', 'Post-menopause', 'Several years past menopause'],
      ['exploring', 'Not sure yet', 'Still figuring out where I am']
    ].each do |value, label, description| %>
      <div class="form-check stage-option mb-3">
        <%= form.radio_button :stage, value, 
            class: 'form-check-input', 
            id: "stage_#{value}",
            checked: (@session_profile[:stage] == value) %>
        <label class="form-check-label w-100" for="stage_<%= value %>">
          <div class="stage-card p-3 border rounded">
            <h6 class="mb-1"><%= label %></h6>
            <small class="text-muted"><%= description %></small>
          </div>
        </label>
      </div>
    <% end %>
  </div>
<% end %>