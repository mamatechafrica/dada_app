// Show validation errors
<% if @user_profile.errors.any? %>
  // Add error styling to the modal
  document.querySelector('#onboardingModal .modal-content').classList.add('border-danger');
  
  // Create error alert
  var errorHtml = `
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <strong>Please fix the following errors:</strong>
      <ul class="mb-0 mt-2">
        <% @user_profile.errors.full_messages.each do |message| %>
          <li><%= j message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  `;
  
  // Insert error at the top of modal body
  var modalBody = document.querySelector('#onboardingModal .modal-body');
  modalBody.insertAdjacentHTML('afterbegin', errorHtml);
  
  // Remove error styling after 5 seconds
  setTimeout(function() {
    document.querySelector('#onboardingModal .modal-content').classList.remove('border-danger');
  }, 5000);
<% else %>
  // Generic error message
  alert('Something went wrong. Please try again.');
<% end %>