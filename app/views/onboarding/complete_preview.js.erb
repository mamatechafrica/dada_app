// Close the modal with celebration for preview users
document.querySelector('#onboardingModal .modal-content').style.transition = 'opacity 0.5s ease, transform 0.5s ease';
document.querySelector('#onboardingModal .modal-content').style.opacity = '0';
document.querySelector('#onboardingModal .modal-content').style.transform = 'scale(0.9)';

// Show success message
setTimeout(function() {
  const modal = window.dadaOnboardingModal || bootstrap.Modal.getInstance(document.getElementById('onboardingModal'));
  if (modal) {
    modal.hide();
  }
  
  // Show signup encouragement toast for preview users
  if (typeof bootstrap !== 'undefined' && bootstrap.Toast) {
    var toastHtml = `
      <div class="toast align-items-center text-white bg-dada-primary border-0 position-fixed top-0 end-0 m-3" role="alert" style="z-index: 9999;">
        <div class="d-flex">
          <div class="toast-body">
            <i class="fas fa-heart me-2"></i>
            Love your personalized experience? Join our community to save your journey!
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
      </div>
    `;
    
    document.body.insertAdjacentHTML('beforeend', toastHtml);
    var toast = new bootstrap.Toast(document.querySelector('.toast:last-child'), {
      delay: 6000 // Show longer for signup encouragement
    });
    toast.show();
  }
  
  // Show signup modal or redirect after 3 seconds
  setTimeout(function() {
    showSignupEncouragement();
  }, 3000);
}, 500);

function showSignupEncouragement() {
  // Create a signup encouragement modal
  var signupModalHtml = `
    <div class="modal fade" id="signupEncouragementModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header border-0 bg-dada-primary text-white">
            <h5 class="modal-title">Ready to Begin Your Journey?</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body text-center">
            <div class="mb-3">
              <i class="fas fa-hands-helping fa-3x text-dada-primary mb-3"></i>
            </div>
            <h6>You've experienced your personalized Dada preview!</h6>
            <p class="text-muted">Join our community to:</p>
            <ul class="list-unstyled">
              <li><i class="fas fa-check text-success me-2"></i>Save your personalized content</li>
              <li><i class="fas fa-check text-success me-2"></i>Connect with other African women</li>
              <li><i class="fas fa-check text-success me-2"></i>Access our AI chat support</li>
              <li><i class="fas fa-check text-success me-2"></i>Join discussion forums</li>
            </ul>
          </div>
          <div class="modal-footer border-0">
            <a href="/users/sign_up" class="btn btn-dada-primary w-100">Join Our Community</a>
            <a href="/" class="btn btn-outline-secondary w-100 mt-2">Continue Browsing</a>
          </div>
        </div>
      </div>
    </div>
  `;
  
  document.body.insertAdjacentHTML('beforeend', signupModalHtml);
  var signupModal = new bootstrap.Modal(document.getElementById('signupEncouragementModal'));
  signupModal.show();
}