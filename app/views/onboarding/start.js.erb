// Initialize the modal using Bootstrap 5 syntax
const modalElement = document.getElementById('onboardingModal');
if (modalElement) {
  const modal = new bootstrap.Modal(modalElement);
  modal.show();
  
  // Store modal instance for later use
  window.dadaOnboardingModal = modal;
  
  // Initialize the onboarding controller
  const onboardingController = application.getControllerForElementAndIdentifier(modalElement, 'onboarding');
  if (onboardingController) {
    onboardingController.currentStepValue = 1;
    onboardingController.updateDisplay();
  }
} else {
  console.error('Onboarding modal not found');
}