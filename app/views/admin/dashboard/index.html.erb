<div class="p-8">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-gray-500">Welcome back! Here's what's happening.</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Total Stories</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= Share.count %></p>
        </div>
        <div class="w-12 h-12 rounded-full bg-dada-primary/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-dada-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Resources</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= Resource.count %></p>
        </div>
        <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center">
          <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Flagged</p>
          <p class="text-3xl font-bold text-yellow-600 mt-1"><%= Share.flagged.count %></p>
        </div>
        <div class="w-12 h-12 rounded-full bg-yellow-50 flex items-center justify-center">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Tags</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= Tag.count %></p>
        </div>
        <div class="w-12 h-12 rounded-full bg-purple-50 flex items-center justify-center">
          <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions & Recent -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h2>
      <div class="grid grid-cols-2 gap-3">
        <%= link_to new_admin_resource_path, class: "flex flex-col items-center justify-center p-4 rounded-lg bg-dada-primary text-white hover:bg-dada-accent transition" do %>
          <svg class="w-6 h-6 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          <span class="font-medium">Add Resource</span>
        <% end %>
        
        <%= link_to admin_moderation_path, class: "flex flex-col items-center justify-center p-4 rounded-lg border-2 border-dada-primary text-dada-primary hover:bg-dada-primary hover:text-white transition" do %>
          <svg class="w-6 h-6 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="font-medium">Moderation</span>
        <% end %>
      </div>
    </div>
    
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Stories</h2>
      <div class="space-y-3">
        <% Share.order(created_at: :desc).limit(5).each do |share| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-dada-secondary/30 flex items-center justify-center text-dada-primary text-sm font-medium">
                <%= share.user&.name&.first&.upcase || "?" %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900 truncate max-w-[200px]"><%= share.title || "Untitled" %></p>
                <p class="text-xs text-gray-500"><%= time_ago_in_words(share.created_at) %> ago</p>
              </div>
            </div>
            <span class="text-xs px-2 py-1 rounded-full <%= share.status == 'published' ? 'bg-green-100 text-green-700' : share.status == 'flagged' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-700' %>">
              <%= share.status %>
            </span>
          </div>
        <% end %>
        
        <% if Share.count == 0 %>
          <p class="text-sm text-gray-500 text-center py-4">No stories yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
