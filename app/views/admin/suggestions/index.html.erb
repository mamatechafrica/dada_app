<div class="p-8">
  <h1 class="text-2xl font-bold mb-6">Topic Suggestions</h1>

  <% if @suggestions.any? %>
    <div class="space-y-4">
      <% @suggestions.each do |suggestion| %>
        <div class="bg-white rounded-lg shadow p-6 border border-gray-200">
          <div class="flex justify-between items-start">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded">Pending</span>
                <% if suggestion.circle %>
                  <span class="text-sm text-gray-500"><%= suggestion.circle.name %></span>
                <% else %>
                  <span class="text-sm text-gray-500">New circle will be created</span>
                <% end %>
              </div>
              <h3 class="text-lg font-semibold mb-1"><%= suggestion.title %></h3>
              <p class="text-gray-600 mb-2"><%= suggestion.description %></p>
              <p class="text-sm text-gray-500">
                Suggested by <%= suggestion.user.name || suggestion.user.email %> 
                · <%= time_ago_in_words(suggestion.created_at) %> ago
              </p>
            </div>
            <div class="flex gap-2 ml-4">
              <%= button_to "Approve & Create", admin_approve_suggestion_path(suggestion), method: :post, class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700" %>
              <%= button_to "Reject", admin_reject_suggestion_path(suggestion), method: :post, class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-8 text-center">
      <p class="text-gray-500">No pending suggestions</p>
    </div>
  <% end %>
</div>
